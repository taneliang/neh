{
  "compilerOptions": {
    "alwaysStrict": true,
    "esModuleInterop": true,
    "lib": ["esnext", "es2015.promise"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "preserveConstEnums": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": ["@cloudflare/workers-types", "vitest/globals", "node"],
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": ["./src/typings.d.ts", "./src/*.ts", "./src/**/*.ts", "./scripts/**/*.ts"],
  "exclude": ["node_modules/", "dist/"]
}
